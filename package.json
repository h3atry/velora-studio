{
  "name": "velora",
  "version": "0.1.0",
  "author": "Velora Studio",
  "description": "Velora — estúdio multicanal de live (TikTok + Twitch)",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "shortcuts": "powershell -NoProfile -File scripts/create-shortcuts.ps1",
    "build": "tsc --noEmit && vite build && electron-builder --win dir",
    "build:installer": "tsc --noEmit && vite build && electron-builder --win nsis",
    "build:ci": "npm run build || npm run build:installer",
    "sync": "powershell -NoProfile -File sync-build.ps1",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "tiktok:portal": "node scripts/tiktok-portal-fill.mjs",
    "lint": "eslint src electron --ext .ts,.tsx"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.469.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selfsigned": "^5.5.0",
    "tiktok-live-connector": "^2.4.0",
    "tmi.js": "^1.8.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.velora.studio",
    "productName": "Velora",
    "directories": {
      "output": "release",
      "buildResources": "public/brand"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/tmi.js/**/*",
      "node_modules/tiktok-live-connector/**/*"
    ],
    "extraResources": [
      {
        "from": "oauth-credentials.json",
        "to": "oauth-credentials.json",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg/ffmpeg.exe"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/tmi.js/**",
      "node_modules/tiktok-live-connector/**"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/brand/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "h3atry",
      "repo": "velora-studio"
    }
  }
}
